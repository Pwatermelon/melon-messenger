# Локальная разработка web: cp .env.example .env
# Production: те же VITE_LEGAL_* — как GitHub Secrets (см. deploy/.env.example)

VITE_WEB_URL=https://watermelon-messenger.ru

VITE_LEGAL_OPERATOR_TYPE=individual
VITE_LEGAL_OPERATOR_NAME=Жуков Матвей Сергеевич
VITE_LEGAL_OPERATOR_EMAIL=platinumwatermelon@yandex.ru
# ИНН (12 цифр) — опционально; если указать, появится в политике на сайте
