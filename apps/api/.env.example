DATABASE_URL=postgres://postgres:postgres@localhost:5432/melon
REDIS_URL=redis://localhost:6379
SCYLLA_CONTACT_POINTS=127.0.0.1
SCYLLA_KEYSPACE=melon
SCYLLA_DATACENTER=datacenter1
JWT_SECRET=change-me-in-production
PORT=3000

# Шифрование сообщений at-rest (AES-256-GCM). Base64, ≥32 байт, или произвольная строка.
MESSAGE_AT_REST_KEY=
# ID активного ключа (для ротации). Новые сообщения шифруются этим ключом.
MESSAGE_AT_REST_ACTIVE_KEY_ID=1
# Предыдущие ключи — чтобы читать старые сообщения после смены MESSAGE_AT_REST_KEY:
# MESSAGE_AT_REST_KEY_1=<старый_ключ>
# MESSAGE_AT_REST_KEY_2=<новый_ключ>  (должен совпадать с MESSAGE_AT_REST_KEY)
# После ротации: bun run db:reencrypt-messages — перешифровать ScyllaDB активным ключом

# Yandex OAuth — единственный способ входа
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/auth/yandex/callback
# Native iOS/macOS (зарегистрируйте в oauth.yandex.ru)
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
# Доп. redirect URI через запятую (опционально)
YANDEX_ALLOWED_REDIRECT_URIS=
WEB_URL=http://localhost:5173

# Версии юридических документов (синхронизируйте с web)
LEGAL_PRIVACY_VERSION=1.0
LEGAL_TERMS_VERSION=1.0
LEGAL_CONSENT_VERSION=1.0
LEGAL_EFFECTIVE_DATE=26 июня 2026 г.

# Yandex ID админов
ADMIN_YANDEX_LOGINS=platinumwatermelon
# Числовые Yandex ID (опционально, через запятую)
ADMIN_YANDEX_IDS=

# DonationAlerts — страница добровольной поддержки проекта (кнопка в настройках мессенджера).
# Уведомления принимает отдельный сервис melon-payment (DA_SECRET_TOKEN), не эта ссылка.
DONATION_ALERTS_URL=https://www.donationalerts.com/r/your-page

# Melon Payment — учёт коинов (см. ../melon-payment)
MELON_PAYMENT_URL=http://localhost:3010
MELON_PAYMENT_API_KEY=change-me-integrator-api-key
MELON_PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret

# Web Push в браузере (не email). Ключи: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Опционально — контакт приложения для Google/Mozilla push; по умолчанию WEB_URL

# E2E tests only — disable on public production
E2E_TEST_SECRET=

# Медиа
# Полный docker compose — s3 на http://minio:9000 (в docker-compose.yml).
# bun run dev на хосте — local (или пробрось minio:9000 и s3):
MEDIA_STORAGE=local
# MEDIA_STORAGE=s3
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=watermelon-media
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
