DATABASE_URL=postgres://postgres:postgres@localhost:5432/melon
REDIS_URL=redis://localhost:6379
SCYLLA_CONTACT_POINTS=127.0.0.1
SCYLLA_KEYSPACE=melon
SCYLLA_DATACENTER=datacenter1
JWT_SECRET=change-me-in-production
PORT=3000

# Шифрование сообщений at-rest (AES-256-GCM). Base64, ≥32 байт, или произвольная строка (будет захеширована).
MESSAGE_AT_REST_KEY=

# Yandex OAuth — единственный способ входа
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/auth/yandex/callback
# Native iOS/macOS (зарегистрируйте в oauth.yandex.ru)
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
# Доп. redirect URI через запятую (опционально)
YANDEX_ALLOWED_REDIRECT_URIS=
WEB_URL=http://localhost:5173

# Yandex ID админов — логины через запятую (по умолчанию platinumwatermelon)
ADMIN_YANDEX_LOGINS=platinumwatermelon
# Числовые Yandex ID (опционально, через запятую)
ADMIN_YANDEX_IDS=

# Platinum / YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLATINUM_PRICE_RUB=299
API_PUBLIC_URL=http://localhost:8080/api

# Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@watermelon.local

# E2E tests only — disable on public production
E2E_TEST_SECRET=

# Медиа
# Полный docker compose — s3 на http://minio:9000 (в docker-compose.yml).
# bun run dev на хосте — local (или пробрось minio:9000 и s3):
MEDIA_STORAGE=local
# MEDIA_STORAGE=s3
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=watermelon-media
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
