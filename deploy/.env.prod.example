# Copy to GitHub Secret PROD_ENV_FILE (entire file contents) and keep a local copy as .env.prod
# On each release "ver X.Y.Z" this file is rsync'd to the server as .env.prod

NODE_ENV=production
WM_DOMAIN=watermelon-messenger.ru

# Docker Hub: plwatermelon/watermelon-messenger-{api,web}:X.Y.Z
# WM_VERSION задаётся при деплое (ver X.Y.Z) — deploy-server.sh пропишет сюда автоматически
WM_VERSION=

# Let's Encrypt / certbot (первый сертификат: ./scripts/certbot-init.sh)
# Пароля нет — только email для уведомлений Let's Encrypt. Продление автоматическое (контейнер certbot).
CERTBOT_EMAIL=you@example.com

# Database
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security — REQUIRED (openssl rand -base64 48)
JWT_SECRET=
MESSAGE_AT_REST_KEY=

# Yandex OAuth — https://oauth.yandex.ru/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://watermelon-messenger.ru/api/auth/yandex/callback
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
WEB_URL=https://watermelon-messenger.ru

ADMIN_YANDEX_LOGINS=platinumwatermelon
ADMIN_YANDEX_IDS=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLATINUM_PRICE_RUB=299
API_PUBLIC_URL=https://watermelon-messenger.ru/api

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@watermelon-messenger.ru
