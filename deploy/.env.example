# =============================================================================
# PRODUCTION .env — полный шаблон для сервера и GitHub Secret PROD_ENV_FILE
# =============================================================================
#
# Как использовать:
#   1. Скопируйте этот файл, заполните значения ниже.
#   2. GitHub → Settings → Secrets → PROD_ENV_FILE = ВСЁ содержимое файла (многострочный секрет).
#   3. При каждом релизе (ver X.Y.Z) CI перезапишет /opt/watermelon-messenger/.env на сервере.
#
# Отдельные секреты GitHub (Settings → Secrets → Actions):
#   DOCKERHUB_TOKEN
#   DEPLOY_SSH_HOST / DEPLOY_SSH_USER / DEPLOY_SSH_KEY / DEPLOY_PATH
#   PROD_ENV_FILE              — блок «СЕРВЕР» ниже (API, БД, OAuth…)
#   VITE_YANDEX_MAPS_API_KEY   — Яндекс.Карты (опционально)
#   VITE_YANDEX_METRIKA_ID     — счётчик Яндекс Метрики (опционально, ускоряет индексирование)
#   VITE_LEGAL_OPERATOR_NAME   — ФИО в политике (если пусто — из кода: Жуков Матвей Сергеевич)
#   VITE_LEGAL_OPERATOR_EMAIL  — platinumwatermelon@yandex.ru
#   VITE_LEGAL_OPERATOR_INN    — ИНН 12 цифр (опционально, попадёт в политику на сайте)
#
# ИНН и ФИО НЕ в PROD_ENV_FILE — они вшиваются в web-образ при сборке (secrets выше).
# Адрес дома на сайт не указываем; в форме РКН — указывается отдельно на pd.rkn.gov.ru
# =============================================================================

# --- Инфраструктура / деплой ---
NODE_ENV=production
WM_DOMAIN=watermelon-messenger.ru
# До certbot: nginx.http.conf → после certbot-init.sh станет nginx.prod.conf
WM_NGINX_CONF=nginx.http.conf
# WM_VERSION прописывает deploy-server.sh при релизе; вручную не нужно
WM_VERSION=
# Email для Let's Encrypt (certbot)
CERTBOT_EMAIL=platinumwatermelon@yandex.ru

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Безопасность API ---
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=
# Сгенерировать: openssl rand -base64 32
MESSAGE_AT_REST_KEY=
# Ротация ключей (см. apps/api/KEY_ROTATION.md): активный ID + старые ключи в MESSAGE_AT_REST_KEY_N
MESSAGE_AT_REST_ACTIVE_KEY_ID=1
# MESSAGE_AT_REST_KEY_1=

# --- Yandex OAuth ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://watermelon-messenger.ru/api/auth/yandex/callback
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
WEB_URL=https://watermelon-messenger.ru

# --- Админы (Yandex login / ID) ---
ADMIN_YANDEX_LOGINS=platinumwatermelon
ADMIN_YANDEX_IDS=

# --- Юридические документы (API — проверка версий согласий) ---
LEGAL_PRIVACY_VERSION=1.0
LEGAL_TERMS_VERSION=1.0
LEGAL_CONSENT_VERSION=1.0
LEGAL_EFFECTIVE_DATE=26 июня 2026 г.

# --- Melon Payment (коины — подарок за поддержку) ---
MELON_PAYMENT_URL=http://melon-payment:3010
MELON_PAYMENT_API_KEY=
MELON_PAYMENT_WEBHOOK_SECRET=

# --- DonationAlerts: страница поддержки проекта (кнопка в настройках) ---
# Уведомления принимает melon-payment (DA_SECRET_TOKEN в его .env), см. ../melon-payment/README.md
DONATION_ALERTS_URL=https://www.donationalerts.com/r/your-page

API_PUBLIC_URL=https://watermelon-messenger.ru/api

# --- MinIO / S3 (медиафайлы) — ОБЯЗАТЕЛЬНО ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_BUCKET=watermelon-media

# --- Web Push (опционально) ---
# Сгенерировать: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:platinumwatermelon@yandex.ru

# --- Grafana (опционально, внутренний мониторинг) ---
# GRAFANA_ADMIN_PASSWORD=change-me

# =============================================================================
# НЕ КОПИРОВАТЬ В PROD_ENV_FILE — GitHub Secrets для сборки web (см. заголовок файла)
# =============================================================================
# VITE_LEGAL_OPERATOR_NAME=Жуков Матвей Сергеевич
# VITE_LEGAL_OPERATOR_EMAIL=platinumwatermelon@yandex.ru
# VITE_LEGAL_OPERATOR_INN=123456789012
# VITE_YANDEX_MAPS_API_KEY=
